# Copy to .env (gitignored) and fill in. NEVER commit real keys.
#   cp .env.example .env
#
# This single repo-root .env is the ONLY config file you need — both the Python
# agent and the Next.js web app read it. (No per-folder .env.local required.)
# For the hackathon demo, ask Tony for the filled-in values.

# --- Required for the live demo ---

# LiveKit — the room, the agent worker, and STT/LLM/TTS via LiveKit Inference
# (no separate OpenAI/Deepgram/Cartesia keys needed).
# Get from https://cloud.livekit.io (Project Settings -> Keys), or run `lk app env`.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Agent dispatch name — the web app dispatches the clone explicitly to the worker
# registered as `agent-py` (see agent.py). Leave this exactly as-is.
AGENT_NAME=agent-py

# Moss — semantic retrieval of the persona's real context. https://portal.usemoss.dev
MOSS_PROJECT_ID=
MOSS_PROJECT_KEY=

# Qwen voice clone via Alibaba DashScope (international endpoint) — the clone's
# spoken voice. https://dashscope.console.aliyun.com
DASHSCOPE_API_KEY=

# Slack — channel the post-standup summary is posted to (Incoming Webhook).
# https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# --- Optional (only to re-pull the corpus from Linear; Melody's lane) ---
# LINEAR_API_KEY=
# LINEAR_ABSENT_USER_ID=   # uv run --project agent-py python scripts/pull_linear.py --list-users
