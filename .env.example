# Copy to .env (gitignored) and fill in. NEVER commit real keys.
#   cp .env.example .env

# Moss — retrieval (Nuha) — get from https://portal.usemoss.dev
MOSS_PROJECT_ID=
MOSS_PROJECT_KEY=

# LLM — answer generation (TrueFoundry gateway or direct)
LLM_API_KEY=
# LLM_BASE_URL=        # set if using a gateway

# LiveKit — room / agent (Tony)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Voice clone / TTS (Nuha) — Qwen primary, Minimax fallback
QWEN_API_KEY=
MINIMAX_API_KEY=

# Slack — summary channel (Tony)
SLACK_WEBHOOK_URL=

# Linear — ticket ingestion (Melody, scripts/pull_linear.py)
LINEAR_API_KEY=
LINEAR_ABSENT_USER_ID=        # run `python scripts/pull_linear.py --list-users` to find this
